// Prisma schema — single-file (prisma.config.ts points at prisma/schema.prisma).
// Consolidated from the former prisma/models/*.prisma on 2026-07-10 when the
// project moved to a fresh Prisma Postgres database for AI Software Architect.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Projects & collaboration ────────────────────────────────────────────────

enum ProjectStatus {
  DRAFT
  ARCHIVED
}

model Project {
  id            String        @id @default(cuid())
  ownerId       String
  name          String
  description   String?
  status        ProjectStatus @default(DRAFT)
  canvasBlobUrl String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  collaborators ProjectCollaborator[]
  specs         ProjectSpec[]
  memory        ProjectMemory?
  runs          Run[]

  @@index([ownerId])
  @@index([createdAt])
}

model ProjectCollaborator {
  id        String   @id @default(cuid())
  projectId String
  email     String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, email])
  @@index([email])
  @@index([projectId, createdAt])
}

model ProjectSpec {
  id        String   @id @default(cuid())
  projectId String
  filePath  String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ─── Legacy background-task index (design/spec generators) ────────────────────

model TaskRun {
  id        String   @id @default(cuid())
  runId     String   @unique
  projectId String
  userId    String
  createdAt DateTime @default(now())

  @@index([runId])
  @@index([userId, projectId])
}

// ─── Shared Memory runtime (Phase 1) ─────────────────────────────────────────

model ProjectMemory {
  id            String   @id @default(cuid())
  projectId     String   @unique
  document      Json
  memoryVersion Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revisions MemoryRevision[]
}

model MemoryRevision {
  id              String   @id @default(cuid())
  memoryId        String
  version         Int
  agentId         String
  runId           String?
  stepId          String?
  changedSections Json
  createdAt       DateTime @default(now())

  memory ProjectMemory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@unique([memoryId, version])
  @@index([memoryId, createdAt])
}

// ─── Orchestrator runtime (Phase 2) ──────────────────────────────────────────

/// DONE is the canonical "completed" state. A run that finished with blocked
/// sections is DONE with a non-empty `blockages` — the run is not blocked, its
/// sections are (orchestrator.md prime directive 5), so there is no BLOCKED status.
enum RunStatus {
  RUNNING
  WAITING_CLARIFICATION
  RESUMING
  DONE
  FAILED
}

model Run {
  id           String    @id @default(cuid())
  projectId    String
  userId       String
  intent       String
  phase        String
  /// Step the run is currently on — lets a resumed run be traced to its exact place.
  stepId       String?
  status       RunStatus @default(RUNNING)
  plan         Json
  blockages    Json?
  /// Clarification waitpoint state: token id, asked question ids, expiry and
  /// suspend/resume timestamps. Question *text* stays in Shared Memory (single
  /// source of truth); only references are duplicated here.
  clarification Json?
  triggerRunId String?   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}
