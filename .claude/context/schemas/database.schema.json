{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-software-architect.dev/schemas/database.schema.json",
  "title": "Database Section",
  "description": "The `database` section of Shared Memory, owned by architecture/database_architect. Every ENT-* must appear in a table mapping or in notPersisted (enforced by rules/consistency.md).",
  "type": "object",
  "required": ["engine", "tables"],
  "properties": {
    "engine": {
      "type": "object",
      "required": ["family", "product", "justification"],
      "properties": {
        "family": { "enum": ["relational", "document", "keyValue", "graph", "timeSeries", "mixed"] },
        "product": { "type": "string" },
        "justification": { "type": "string" },
        "adr": { "type": "string", "pattern": "^ADR-" }
      }
    },
    "tables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "entity", "columns", "primaryKey"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "entity": { "type": "string", "pattern": "^ENT-", "description": "The entity this table persists" },
          "columns": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "type", "nullable"],
              "properties": {
                "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
                "type": { "type": "string", "description": "Physical type in the chosen engine, e.g. varchar(255), numeric(12,2), timestamptz" },
                "nullable": { "type": "boolean" },
                "default": { "type": "string" },
                "unique": { "type": "boolean" },
                "enumValues": { "type": "array", "items": { "type": "string" } },
                "attribute": { "type": "string", "description": "Source entity attribute name" }
              }
            }
          },
          "primaryKey": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "foreignKeys": {
            "type": "array",
            "items": { "type": "object", "required": ["columns", "referencesTable", "referencesColumns", "onDelete"], "properties": { "columns": { "type": "array", "items": { "type": "string" } }, "referencesTable": { "type": "string" }, "referencesColumns": { "type": "array", "items": { "type": "string" } }, "onDelete": { "enum": ["cascade", "restrict", "setNull"] } } }
          },
          "indexes": {
            "type": "array",
            "items": { "type": "object", "required": ["columns", "justification"], "properties": { "name": { "type": "string" }, "columns": { "type": "array", "minItems": 1, "items": { "type": "string" } }, "unique": { "type": "boolean" }, "justification": { "type": "string", "description": "The query pattern (story/requirement) that motivates this index" } } }
          },
          "kind": { "enum": ["entity", "junction", "lookup"], "default": "entity" }
        }
      }
    },
    "notPersisted": {
      "type": "array",
      "items": { "type": "object", "required": ["entity", "reason"], "properties": { "entity": { "type": "string", "pattern": "^ENT-" }, "reason": { "type": "string" } } }
    },
    "relations": {
      "type": "array",
      "description": "ERD-level view used for diagram projection",
      "items": { "type": "object", "required": ["from", "to", "cardinality"], "properties": { "from": { "type": "string" }, "to": { "type": "string" }, "cardinality": { "enum": ["one-to-one", "one-to-many", "many-to-many"] }, "via": { "type": "string", "description": "Junction table for many-to-many" }, "label": { "type": "string" } } }
    },
    "ruleEnforcement": {
      "type": "array",
      "items": { "type": "object", "required": ["rule", "layer"], "properties": { "rule": { "type": "string", "pattern": "^BR-" }, "layer": { "enum": ["data-layer", "app-layer"] }, "mechanism": { "type": "string", "description": "e.g. FK constraint, check constraint, service invariant" } } }
    },
    "evolution": {
      "type": "object",
      "properties": {
        "migrationStrategy": { "type": "string" },
        "softDeletePolicy": { "type": "string" },
        "timestampConvention": { "type": "string" }
      }
    },
    "canvasProjection": { "type": "object", "description": "ERD React Flow projection per prompts/output_formats.md (cylinders, teal palette)" }
  }
}
