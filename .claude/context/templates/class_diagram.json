      { "id": "ent-customer", "label": "Customer", "shape": "rectangle", "colorIndex": 5, "x": 100, "y": 280, "width": 180, "height": 100 },
      { "id": "order-status", "label": "«enum» OrderStatus", "shape": "pill", "colorIndex": 0, "x": 380, "y": 280, "width": 180, "height": 80 }
