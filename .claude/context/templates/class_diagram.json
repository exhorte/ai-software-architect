    { "id": "edge-order-customer", "from": "ent-order", "to": "ent-customer", "kind": "association", "label": "placed by (by ID — crosses aggregate boundary)", "cardinalityFrom": "*", "cardinalityTo": "1" },
    { "id": "edge-order-orderstatus", "from": "ent-order", "to": "order-status", "kind": "dependency" }
